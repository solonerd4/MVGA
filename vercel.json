{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/yes_page.html",
      "destination": "/vote",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/home.html"
    }
  ]
}
